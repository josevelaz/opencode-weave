{
  "id": "tapestry-disabled-reviewers-contract",
  "title": "Tapestry removes delegated review when Weft and Warp are disabled",
  "phase": "prompt",
  "tags": ["prompt", "composer", "tapestry", "variants"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "tapestry",
    "variant": {
      "disabledAgents": ["weft", "warp"]
    }
  },
  "executor": {
    "kind": "prompt-render"
  },
  "evaluators": [
    { "kind": "xml-sections-present", "sections": ["PostExecutionReview"] },
    { "kind": "section-contains-all", "section": "PostExecutionReview", "patterns": ["Report the summary of all changes", "Identify all changed files"] },
    { "kind": "excludes-all", "patterns": ["subagent_type \"weft\"", "subagent_type \"warp\"", "Task tool"] }
  ]
}
