{
  "id": "tapestry-continue-after-progress-update",
  "title": "Tapestry continues after a mid-plan progress update",
  "description": "Checks that Tapestry treats a routine progress report as non-terminal when unchecked plan tasks remain and no blocked state is recorded.",
  "phase": "experimental",
  "tags": ["experimental", "tapestry", "execution-contract", "continuation"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "tapestry"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "You are actively executing /start-work. The plan is 2/5 complete. You just finished task 2 and posted a brief progress update. Tasks 3, 4, and 5 are still unchecked, no blocker or pause has been recorded, and the user has not interrupted. What should you do next?"
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "expectedAnyOf": ["continue", "next unchecked task", "task 3", "keep working"],
      "forbiddenContains": ["weft", "warp", "review", "all tasks complete", "plan execution is complete"]
    }
  ]
}
