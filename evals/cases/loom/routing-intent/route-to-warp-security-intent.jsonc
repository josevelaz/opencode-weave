{
  "id": "route-to-warp-security-intent",
  "title": "Intent: preserves security-review workflow for sensitive asks",
  "description": "Accepts the expected security-review behavior when Loom clearly routes the request through a security audit path rather than skipping review.",
  "phase": "routing",
  "tags": ["routing", "loom", "intent", "security"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "Review authentication and token handling changes for security issues before shipping."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "rubricRef": "evals/rubrics/loom-routing-rubric.md",
      "expectedAnyOf": ["warp", "security audit", "security review"],
      "forbiddenContains": ["skip security review"]
    }
  ]
}
