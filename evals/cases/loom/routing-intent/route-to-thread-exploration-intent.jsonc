{
  "id": "route-to-thread-exploration-intent",
  "title": "Intent: delegates exploration work instead of doing it directly",
  "description": "Accepts the expected exploration workflow when Loom names Thread or otherwise clearly frames the response as codebase exploration rather than direct implementation.",
  "phase": "routing",
  "tags": ["routing", "loom", "intent"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "Find all authentication-related files and summarize their responsibilities."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "rubricRef": "evals/rubrics/loom-routing-rubric.md",
      "expectedAnyOf": ["thread", "exploration"],
      "forbiddenContains": ["implement directly"]
    }
  ]
}
