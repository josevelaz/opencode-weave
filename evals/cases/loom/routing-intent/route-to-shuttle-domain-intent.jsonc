{
  "id": "route-to-shuttle-domain-intent",
  "title": "Intent: routes specialist domain work to the specialist workflow",
  "description": "Accepts the expected specialist-domain behavior when Loom frames the GraphQL request around domain expertise rather than planning or direct implementation.",
  "phase": "routing",
  "tags": ["routing", "loom", "intent"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "We have a product catalog domain that needs GraphQL schema generation — types, resolvers, and input validation. Please delegate to the right specialist agent for this domain work."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "rubricRef": "evals/rubrics/loom-routing-rubric.md",
      "expectedAnyOf": ["shuttle", "specialist", "domain expertise"],
      "forbiddenContains": ["I will implement this directly"]
    }
  ]
}
