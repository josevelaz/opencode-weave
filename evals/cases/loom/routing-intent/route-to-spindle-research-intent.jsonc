{
  "id": "route-to-spindle-research-intent",
  "title": "Intent: routes external research through a research workflow",
  "description": "Accepts the expected research behavior when Loom clearly treats the request as external-docs research instead of answering from memory or implementing directly.",
  "phase": "routing",
  "tags": ["routing", "loom", "intent"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "Research how the Stripe API handles idempotency keys and summarize the best practices from their docs."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "expectedAnyOf": ["spindle", "research", "docs"],
      "forbiddenContains": ["implement directly", "I'll handle this myself"]
    }
  ]
}
