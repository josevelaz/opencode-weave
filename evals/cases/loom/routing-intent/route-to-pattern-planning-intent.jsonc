{
  "id": "route-to-pattern-planning-intent",
  "title": "Intent: routes planning-heavy implementation work through planning workflow",
  "description": "Accepts the expected orchestration behavior when Loom frames the response around planning, scoping, or handing execution off through `/start-work` rather than implementing directly.",
  "phase": "routing",
  "tags": ["routing", "loom", "intent"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "Implement a multi-file feature with data model updates, API changes, and integration tests."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "rubricRef": "evals/rubrics/loom-routing-rubric.md",
      "expectedAnyOf": ["pattern", "plan", "/start-work"],
      "forbiddenContains": ["I will implement this directly"]
    }
  ]
}
