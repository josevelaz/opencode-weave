{
  "id": "ambiguous-exploration-security-intent",
  "title": "Intent: accepts either exploration-first or security-first routing on gray-zone asks",
  "description": "Gray-zone coverage: accepts either Thread-led exploration or Warp-led security review as long as Loom delegates instead of handling the auth scan directly.",
  "phase": "routing",
  "tags": ["routing", "loom", "intent", "ambiguous"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "Scan the authentication module for potential security vulnerabilities and summarize what you find."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "expectedAnyOf": ["thread", "warp"],
      "forbiddenContains": ["I'll handle this myself", "implement directly"]
    }
  ]
}
