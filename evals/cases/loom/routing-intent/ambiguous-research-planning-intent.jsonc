{
  "id": "ambiguous-research-planning-intent",
  "title": "Intent: accepts research-first or planning-first orchestration on mixed asks",
  "description": "Mixed-workflow coverage: accepts either Spindle-led research or Pattern-led planning as long as Loom delegates instead of trying to do both itself.",
  "phase": "routing",
  "tags": ["routing", "loom", "intent", "ambiguous"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "Research how other projects implement OAuth2 PKCE flow, then create a plan for adding it to our app."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "expectedAnyOf": ["spindle", "pattern"],
      "forbiddenContains": ["I'll handle this myself", "implement directly"]
    }
  ]
}
