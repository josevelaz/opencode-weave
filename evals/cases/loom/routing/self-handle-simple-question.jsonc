{
  // Quick factual question — no agent delegation should occur
  "id": "self-handle-simple-question",
  "title": "Self-handles simple factual questions without delegation",
  "description": "Verifies that Loom answers simple factual questions (e.g. Promise vs Observable) directly without delegating to any agent.",
  "phase": "routing",
  "tags": ["routing", "loom", "self-handle"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openrouter",
    "model": "openai/gpt-5.4",
    "input": "What's the difference between a Promise and an Observable in JavaScript?"
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "forbiddenContains": ["thread", "pattern", "spindle", "warp", "weft", "shuttle", "delegate", "Task"]
    }
  ]
}
