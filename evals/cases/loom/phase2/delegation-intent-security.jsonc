{
  "id": "loom-phase2-delegation-intent-security",
  "title": "Loom model response surfaces Warp for security-sensitive review asks",
  "phase": "routing",
  "tags": ["routing", "loom", "routing", "security"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "github-models",
    "model": "gpt-4o-mini",
    "input": "Review authentication and token handling changes for security issues before shipping."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "rubricRef": "evals/rubrics/loom-routing-rubric.md",
      "expectedContains": ["warp", "security"],
      "forbiddenContains": ["skip security review"]
    }
  ]
}
