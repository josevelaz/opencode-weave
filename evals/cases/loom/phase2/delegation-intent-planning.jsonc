{
  "id": "loom-phase2-delegation-intent-planning",
  "title": "Loom model response prefers Pattern and start-work for complex implementation asks",
  "phase": "phase2",
  "tags": ["phase2", "loom", "pilot", "routing"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "openai",
    "model": "gpt-5",
    "input": "Implement a multi-file feature with data model updates, API changes, and integration tests."
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "rubricRef": "evals/rubrics/loom-routing-rubric.md",
      "expectedContains": ["pattern", "/start-work"],
      "forbiddenContains": ["I will implement this directly"]
    }
  ]
}
