{
  // Spike backport: route-to-weft-review
  // Non-security code review of non-trivial changes (5 files)
  "id": "loom-phase2-route-to-weft-review",
  "title": "Loom model response prefers Weft for non-security multi-file review asks",
  "phase": "routing",
  "tags": ["routing", "loom", "routing", "spike-backport"],
  "target": {
    "kind": "builtin-agent-prompt",
    "agent": "loom"
  },
  "executor": {
    "kind": "model-response",
    "provider": "github-models",
    "model": "gpt-4o-mini",
    "input": "I just refactored the logging module across 5 files. Can you review the changes for quality and consistency?"
  },
  "evaluators": [
    {
      "kind": "llm-judge",
      "expectedContains": ["weft"],
      "forbiddenContains": ["I'll handle this myself"]
    }
  ]
}
